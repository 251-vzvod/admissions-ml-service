ENABLE_LLM=false

# One universal LLM config block.
# Switch provider by changing only these 4 fields:
# - LLM_PROVIDER
# - LLM_MODEL
# - LLM_BASE_URL
# - LLM_API_KEY
#
# Recommended presets:
#
# OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
#
# Ollama local
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=llama3.1:8b
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
#
# Ollama Cloud
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=glm-4.6:cloud
# LLM_BASE_URL=https://ollama.com/v1
# LLM_API_KEY=your_ollama_api_key_here
#
# Groq
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your_groq_api_key_here

LLM_PROVIDER=openai-compatible
LLM_MODEL=glm-4.6:cloud
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=0.6
LLM_RETRY_JITTER_SECONDS=0.2
LLM_FALLBACK_TO_BASELINE=true
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=your_ollama_api_key_here

# Lightweight deploy-safe default.
SEMANTIC_BACKEND=tfidf-char-ngram

# Optional heavier semantic mode:
# SEMANTIC_BACKEND=sentence-transformer
# SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2

AI_DETECTOR_ENABLED=false
AI_DETECTOR_MODEL=desklib/ai-text-detector-v1.01
AI_DETECTOR_MIN_WORDS=60
AI_DETECTOR_ENGLISH_ONLY=true
AI_DETECTOR_ELEVATED_PROBABILITY_THRESHOLD=0.80
